{
  "name": "panodi-cloud-env",
  "version": "1.0.0",
  "private": true,
  "workspaces": [
    "apps/*",
    "swarmops",
    "delusion-check",
    "fissure-care",
    "nexus-edge",
    "pixel-empire",
    "weather-bridge",
    "crazy-combat-game"
  ],
  "scripts": {
    "dev:sovereign": "npm --workspace=apps/sovereign-gpt-web run dev",
    "dev:swarmops": "npm --workspace=swarmops run dev",
    "dev:delusion": "npm --workspace=delusion-check run dev",
    "build:sovereign": "npm --workspace=apps/sovereign-gpt-web run build",
    "build:swarmops": "npm --workspace=swarmops run build"
  }
}
